# Secret HMAC pour signer/vérifier les tokens d'accès client.
# Generer une valeur random 32+ chars : `openssl rand -base64 32`
# MEME valeur que celle utilisee cote Make (Flux C) pour signer.
TOKEN_SECRET=

# Cle API Inter-Fast (meme que celle utilisee dans Make, scenario 143950).
# Si vide, l'app tombe en mode mock (data hardcodee VOISIN) — pratique pour itérer UI sans IF.
IF_API_KEY=
IF_API_BASE=https://api.interfast.io/v1
